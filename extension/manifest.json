{
  "manifest_version": 3,
  "name": "Vibe AI - What Should I Watch?",
  "version": "1.0.0",
  "description": "AI-powered content recommendations. Ask 'What should I watch?' and get personalized suggestions from TMDb, YouTube, and Paramount+.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Vibe AI Recommendations"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8888/*",
    "https://api.themoviedb.org/*",
    "https://www.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.youtube.com/*",
        "*://*.paramountplus.com/*",
        "*://*.hulu.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hbomax.com/*",
        "*://*.max.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
